# Copy this file to .env and fill in your deployment values.

# Database
POSTGRES_USER=caldera
POSTGRES_PASSWORD=change_me_database_password
POSTGRES_DB=calderadb
DATABASE_URL=postgresql://caldera:change_me_database_password@db:5432/calderadb

# OAuth (Google)
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
REDIRECT_URI=https://your-domain.com/auth

# Session
SESSION_SECRET=replace_with_long_random_session_secret
SESSION_HTTPS_ONLY=true

# Optional app config
DIRECTOR_EMAILS=
OLLAMA_MODEL=CalderaAI:latest
OLLAMA_URL=http://host.docker.internal:11434/api/generate
MEDIAMTX_RTMP_PORT=1935
